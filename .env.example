## Example environment variables for Triton Client Manager
##
## This file is **only a template**. It must never contain real secrets.
##
## Usage:
##   1. Copy this file to `.env`.
##   2. Replace every `CHANGE_ME_...` value with environment‑specific data.
##   3. Ensure `.env` is not committed to version control.

#########################
# Core runtime / environment
#########################

# Runtime environment for the manager and manifests.
# Typical values: development | staging | production
TCM_ENV=development

#########################
# Integration tests with real backends (optional)
#########################

# Enable real backend tests only in controlled environments.
# 0 = disabled (default), 1 = enabled
TCM_RUN_REAL_BACKENDS=0

# WebSocket URL of a running Triton Client Manager instance (when
# TCM_RUN_REAL_BACKENDS=1), for example: ws://localhost:8000/ws
TCM_REAL_MANAGER_WS_URL=ws://localhost:8000/ws

# Name of a real model deployed in Triton for test_integration_backends.py
TCM_REAL_MODEL_NAME=CHANGE_ME_REAL_MODEL_NAME

#########################
# OpenStack integration
#########################

# Keystone authentication endpoint (v3). Ask your OpenStack admin
# if you are unsure about the correct URL.
OPENSTACK_AUTH_URL=https://keystone.example.com:5000/v3/auth/tokens

# Application credential used by the manager to talk to OpenStack.
OPENSTACK_APPLICATION_CREDENTIAL_ID=CHANGE_ME_OPENSTACK_APPLICATION_CREDENTIAL_ID
OPENSTACK_APPLICATION_CREDENTIAL_SECRET=CHANGE_ME_OPENSTACK_APPLICATION_CREDENTIAL_SECRET

# Region name for the OpenStack deployment (e.g. RegionOne).
OPENSTACK_REGION_NAME=CHANGE_ME_OPENSTACK_REGION_NAME

# Whether to verify SSL certificates when talking to OpenStack.
# Allowed values: true | false
OPENSTACK_VERIFY_SSL=true

#########################
# Docker controller (GitLab registry helper)
#########################

# Personal or CI token with permissions to read from the GitLab
# container registry that hosts your Triton images.
GITLAB_TOKEN=CHANGE_ME_GITLAB_TOKEN

# Name for the pull token as used by apps/docker_controller/config.yaml.
# The default is usually fine, override only if needed.
GITLAB_TOKEN_NAME=docker-vm-pull-token

#########################
# Optional: MinIO / S3-style storage
#########################

# If you use MinIO/S3 for model storage and want to inject credentials
# via environment variables instead of payloads, you can define:
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_REGION=CHANGE_ME_MINIO_REGION

