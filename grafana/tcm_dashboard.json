{
  "title": "Triton Client Manager",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["tcm", "websocket", "queues"],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "WebSocket connections",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        {
          "expr": "rate(tcm_ws_connections_total[5m])",
          "legendFormat": "connections/s",
          "interval": ""
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "WebSocket messages by type",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        {
          "expr": "rate(tcm_ws_messages_total[5m])",
          "legendFormat": "{{type}}",
          "interval": ""
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "WebSocket error rate",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        {
          "expr": "rate(tcm_ws_errors_total[5m]) / rate(tcm_ws_messages_total[5m])",
          "legendFormat": "error rate",
          "interval": ""
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Total queued jobs",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        {
          "expr": "tcm_queue_total_queued",
          "legendFormat": "total_queued",
          "interval": ""
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Queues by type",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        { "expr": "tcm_queue_info_total", "legendFormat": "info", "interval": "" },
        { "expr": "tcm_queue_management_total", "legendFormat": "management", "interval": "" },
        { "expr": "tcm_queue_inference_total", "legendFormat": "inference", "interval": "" }
      ],
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Executor saturation",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        { "expr": "tcm_executor_info_pending", "legendFormat": "info pending", "interval": "" },
        { "expr": "tcm_executor_management_pending", "legendFormat": "management pending", "interval": "" },
        { "expr": "tcm_executor_inference_pending", "legendFormat": "inference pending", "interval": "" },
        { "expr": "tcm_executor_info_available", "legendFormat": "info available", "interval": "" },
        { "expr": "tcm_executor_management_available", "legendFormat": "management available", "interval": "" },
        { "expr": "tcm_executor_inference_available", "legendFormat": "inference available", "interval": "" }
      ],
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Jobs rejected by type",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        {
          "expr": "rate(tcm_jobs_rejected_total[5m])",
          "legendFormat": "{{type}}",
          "interval": ""
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Job processing time (seconds) by type",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        {
          "expr": "rate(tcm_job_processing_seconds_sum[5m]) / rate(tcm_job_processing_seconds_count[5m])",
          "legendFormat": "{{type}}",
          "interval": ""
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Auth failures and rate limit violations",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "targets": [
        {
          "expr": "rate(tcm_auth_failures_total[5m])",
          "legendFormat": "auth_failures {{reason}}",
          "interval": ""
        },
        {
          "expr": "rate(tcm_rate_limit_violations_total[5m])",
          "legendFormat": "rate_limit {{scope}}",
          "interval": ""
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}

{
  "title": "Triton Client Manager",
  "uid": "tcm-main",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["triton-client-manager", "websocket", "queues"],
  "panels": [
    {
      "type": "row",
      "title": "WebSocket Traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "WebSocket Connections",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(tcm_ws_connections_total[5m])",
          "legendFormat": "connections/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WebSocket Messages by Type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(tcm_ws_messages_total[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WebSocket Errors",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(tcm_ws_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "type": "row",
      "title": "Queues and Backpressure",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Total Queued Jobs",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "tcm_queue_total_queued",
          "legendFormat": "total_queued"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queued Jobs by Type",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "tcm_queue_info_total",
          "legendFormat": "info"
        },
        {
          "refId": "B",
          "expr": "tcm_queue_management_total",
          "legendFormat": "management"
        },
        {
          "refId": "C",
          "expr": "tcm_queue_inference_total",
          "legendFormat": "inference"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Executor Pending vs Available Slots",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "refId": "A",
          "expr": "tcm_executor_info_pending",
          "legendFormat": "info_pending"
        },
        {
          "refId": "B",
          "expr": "tcm_executor_management_pending",
          "legendFormat": "management_pending"
        },
        {
          "refId": "C",
          "expr": "tcm_executor_inference_pending",
          "legendFormat": "inference_pending"
        },
        {
          "refId": "D",
          "expr": "tcm_executor_info_available",
          "legendFormat": "info_available"
        },
        {
          "refId": "E",
          "expr": "tcm_executor_management_available",
          "legendFormat": "management_available"
        },
        {
          "refId": "F",
          "expr": "tcm_executor_inference_available",
          "legendFormat": "inference_available"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Jobs Rejected by Type",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(tcm_jobs_rejected_total[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Job Processing Time",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Job Processing Time (seconds) by Type",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 39 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(tcm_job_processing_seconds_bucket[5m])) by (le, type))",
          "legendFormat": "p95 {{type}}"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}

