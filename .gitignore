# Project-specific
_MINIO_COMMANDS
fix_merge.py
fix_all.py
resolve_del.py

# Sensitive keys (never commit)
*.pem
apps/manager/config/*.pem
apps/manager/openstack_tools/openstack_*
apps/manager/openstack_tools/docker-vm/auto-update/config.yaml
apps/manager/config/openstack.yaml
apps/manager/config/openstack.local.yaml
_TRITON_ML
MODEL_CONVERSION

# Local environment (never commit)
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Python tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Virtual environments (venv must live inside apps/manager/)
.venv/
venv/
apps/manager/.venv/
.MOCK_SERVER/mockvenv

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage / local infra (do not commit)
apps/manager/.coverage
apps/manager/coverage.xml
