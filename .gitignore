# Project-specific
_MINIO_COMMANDS
fix_merge.py
fix_all.py
resolve_del.py

# Internal documentation (do not push to GitLab)
docs/internal/

# Sensitive keys (never commit)
*.pem
apps/manager/config/*.pem
